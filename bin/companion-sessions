#!/usr/bin/env node
/*
 * companion-sessions — list the Companion daemon's live watched sessions.
 *
 * Read-only helper used by the concierge orchestrator (see bin/concierge and
 * concierge/CLAUDE.md) to resolve a project's working directory to its live
 * JSONL sessionId, which it then feeds to companion-remote's remote_send_input
 * / remote_get_conversation. sessionIds change when a session restarts, so the
 * concierge re-runs this every turn.
 *
 * Usage:
 *   bin/companion-sessions                 # human-readable table
 *   bin/companion-sessions --json          # JSON array of {id,name,projectPath,...}
 *   bin/companion-sessions --cwd <path>    # print only the sessionId whose
 *                                          # projectPath == <path> (newest wins);
 *                                          # empty output + exit 3 if none found
 *
 * Connection (env overrides, else read from ~/.companion/config.json):
 *   COMPANION_HOST   (default 127.0.0.1)
 *   COMPANION_PORT   (default: first listener port in config, else 9877)
 *   COMPANION_TOKEN  (default: that listener's token from config)
 */
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');

// --- locate ws module (reuse the daemon's installed dependency) ---
const ROOT = path.resolve(__dirname, '..');
let WebSocket;
try {
  WebSocket = require(path.join(ROOT, 'daemon', 'node_modules', 'ws'));
} catch {
  try {
    WebSocket = require(path.join(ROOT, 'mcp', 'node_modules', 'ws'));
  } catch {
    try {
      WebSocket = require('ws');
    } catch {
      console.error(
        'ERROR: cannot find the "ws" module. Build the daemon first (bin/companion setup) or `npm i ws`.'
      );
      process.exit(2);
    }
  }
}

// --- args ---
const args = process.argv.slice(2);
const asJson = args.includes('--json');
const cwdIdx = args.indexOf('--cwd');
const wantCwd = cwdIdx !== -1 ? args[cwdIdx + 1] : null;

// --- resolve connection params ---
function loadDaemonConfig() {
  const candidates = [
    process.env.COMPANION_CONFIG,
    process.env.CONFIG_PATH,
    path.join(os.homedir(), '.companion', 'config.json'),
  ].filter(Boolean);
  for (const p of candidates) {
    try {
      return JSON.parse(fs.readFileSync(p, 'utf-8'));
    } catch {
      /* try next */
    }
  }
  return null;
}

function pickListener(cfg) {
  if (!cfg) return { port: 9877, token: undefined };
  if (Array.isArray(cfg.listeners) && cfg.listeners.length > 0) {
    const l = cfg.listeners[0];
    return { port: l.port || 9877, token: l.token };
  }
  // legacy flat config
  return { port: cfg.port || 9877, token: cfg.token };
}

const cfg = loadDaemonConfig();
const listener = pickListener(cfg);
const HOST = process.env.COMPANION_HOST || '127.0.0.1';
const PORT = Number(process.env.COMPANION_PORT || listener.port || 9877);
const TOKEN = process.env.COMPANION_TOKEN || listener.token;

if (!TOKEN) {
  console.error(
    'ERROR: no daemon token. Set COMPANION_TOKEN or ensure ~/.companion/config.json has a listener token.'
  );
  process.exit(2);
}

function fail(msg, code) {
  console.error(`ERROR: ${msg}`);
  process.exit(code || 1);
}

const url = `ws://${HOST}:${PORT}`;
const ws = new WebSocket(url);

const TIMEOUT_MS = 8000;
const timer = setTimeout(() => {
  fail(`timed out talking to daemon at ${url}`, 4);
}, TIMEOUT_MS);

let authed = false;

ws.on('error', (err) => {
  clearTimeout(timer);
  fail(`cannot reach daemon at ${url}: ${err.message}`, 4);
});

ws.on('open', () => {
  ws.send(JSON.stringify({ type: 'authenticate', token: TOKEN, requestId: 'auth' }));
});

ws.on('message', (raw) => {
  let msg;
  try {
    msg = JSON.parse(raw.toString());
  } catch {
    return;
  }

  if (msg.type === 'authenticated') {
    if (!msg.success) {
      clearTimeout(timer);
      fail(`authentication failed: ${msg.error || 'unknown'}`, 2);
    }
    authed = true;
    ws.send(JSON.stringify({ type: 'get_sessions', requestId: 'list' }));
    return;
  }

  if (msg.type === 'sessions' && authed) {
    clearTimeout(timer);
    const sessions = (msg.payload && msg.payload.sessions) || [];
    finish(sessions);
  }
});

function normalize(p) {
  return (p || '').replace(/\/+$/, '');
}

function finish(sessions) {
  try {
    ws.close();
  } catch {
    /* ignore */
  }

  if (wantCwd) {
    const target = normalize(wantCwd);
    const matches = sessions
      .filter((s) => normalize(s.projectPath) === target)
      .sort((a, b) => (b.lastActivity || 0) - (a.lastActivity || 0));
    if (matches.length === 0) {
      // no session for this cwd — signal with exit 3, no stdout
      process.exit(3);
    }
    process.stdout.write(matches[0].id + '\n');
    process.exit(0);
  }

  if (asJson) {
    process.stdout.write(JSON.stringify(sessions, null, 2) + '\n');
    process.exit(0);
  }

  // human-readable table
  if (sessions.length === 0) {
    console.log('(no watched sessions)');
    process.exit(0);
  }
  const rows = sessions.map((s) => ({
    id: s.id || '',
    name: s.name || '',
    cwd: s.projectPath || '',
    waiting: s.isWaitingForInput ? 'WAITING' : '',
  }));
  const w = (k) => Math.max(k.length, ...rows.map((r) => String(r[k]).length));
  const wid = w('id');
  const wname = w('name');
  const wcwd = w('cwd');
  const hdr = `${'SESSION_ID'.padEnd(wid)}  ${'NAME'.padEnd(wname)}  ${'CWD'.padEnd(wcwd)}  STATE`;
  console.log(hdr);
  for (const r of rows) {
    console.log(
      `${r.id.padEnd(wid)}  ${r.name.padEnd(wname)}  ${r.cwd.padEnd(wcwd)}  ${r.waiting}`
    );
  }
  process.exit(0);
}
